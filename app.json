{
  "expo": {
    "name": "Vibefolio",
    "slug": "vibers-vibefolio",
    "version": "1.0.0",
    "description": "창작자와 평가자가 함께하는 프로젝트 평가 플랫폼. 전문 평가위원과 참여 고객의 피드백으로 프로젝트의 진짜 가치를 발견하세요.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "vibefolio",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#16A34A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibers.vibefolio",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "프로젝트 사진을 찍기 위해 카메라 접근이 필요합니다",
        "NSPhotoLibraryUsageDescription": "프로젝트 이미지를 업로드하기 위해 사진 라이브러리 접근이 필요합니다",
        "NSUserNotificationsUsageDescription": "새로운 프로젝트, 댓글, 좋아요 알림을 받기 위해 알림 권한이 필요합니다",
        "CFBundleAllowMixedLocalizations": true
      },
      "associatedDomains": [
        "applinks:vibefolio.net"
      ],
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16A34A"
      },
      "package": "com.vibers.vibefolio",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "vibefolio.net",
              "pathPrefix": "/project"
            },
            {
              "scheme": "https",
              "host": "vibefolio.net",
              "pathPrefix": "/recruit"
            },
            {
              "scheme": "https",
              "host": "vibefolio.net",
              "pathPrefix": "/user"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "프로젝트 이미지를 업로드하기 위해 사진 라이브러리 접근이 필요합니다",
          "cameraPermission": "프로젝트 사진을 찍기 위해 카메라 접근이 필요합니다"
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "0fadd9e1-510c-43f9-a45c-742502b16bd5"
      },
      "router": {},
      "developer": {
        "name": "Vibefolio",
        "email": "duscontactus@gmail.com",
        "url": "https://www.vibefolio.net"
      },
      "privacyPolicyUrl": "https://www.vibefolio.net/policy/privacy",
      "termsOfServiceUrl": "https://www.vibefolio.net/policy/terms"
    },
    "owner": "juuuno1116"
  }
}
